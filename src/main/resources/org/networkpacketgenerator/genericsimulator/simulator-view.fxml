<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER_LEFT" spacing="15.0" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.networkpacketgenerator.genericsimulator.SimulatorController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <VBox spacing="5.0">
            <Label text="Hedef IP:" style="-fx-font-weight: bold;"/>
            <TextField fx:id="ipTextField" text="127.0.0.1" prefWidth="120.0"/>
        </VBox>

        <VBox spacing="5.0">
            <Label text="Hedef Port:" style="-fx-font-weight: bold;"/>
            <TextField fx:id="portTextField" text="5005" prefWidth="80.0"/>
        </VBox>
    </HBox>

    <VBox spacing="5.0">
        <Label text="Protokol Tipi:" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="protocolComboBox" prefWidth="120.0"/>
    </VBox>

    <VBox spacing="5.0">
        <Label text="Gönderilecek Veri:" style="-fx-font-weight: bold;"/>
        <TextField fx:id="DataTextField"/>
    </VBox>

    <Button fx:id="sendButton" text="Gonder" onAction="#onSendButtonClick"
            prefWidth="150.0" style="-fx-font-size: 14px; -fx-cursor: hand;"/>

</VBox>